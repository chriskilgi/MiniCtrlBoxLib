{
  "name": "MiniCtrlBoxLib",
  "version": "5.0.2",
  "description": "High-level hardware abstraction library for the MiniCtrlBox (OLED, EEPROM, MCP23017, Buttons, CAN, etc.)",
  "keywords": [
    "oled",
    "ssd1306",
    "gfx",
    "i2c",
    "eeprom",
    "mcp23017",
    "button",
    "input",
    "embedded",
    "esp32",
    "minictrlbox"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chriskilgi/MiniCtrlBoxLib"
  },
  "authors": [
    {
      "name": "C. Kilgenstein",
      "email": "christoph@kilgenstein.eu",
      "url": "https://kilgenstein.eu",
      "maintainer": true
    }
  ],
  "license": "MIT",
  "frameworks": "arduino",
  "platforms": "espressif32",
  "build": {
    "includeDir": "include",
    "srcDir": "src"
  },
  "dependencies": [
    { "name": "adafruit/Adafruit GFX Library", "version": "^1.12.5" },
    { "name": "adafruit/Adafruit BusIO", "version": "^1.17.4" },
    { "name": "adafruit/Adafruit SSD1306", "version": "^2.5.16" },
    { "name": "wollewald/MCP23017_WE", "version": "^1.6.10" },
    { "name": "robtillaart/I2C_EEPROM", "version": "^1.9.4" },
    { "name": "adafruit/Adafruit PWM Servo Driver Library", "version": "^3.0.3" },
    { "name": "adafruit/Adafruit AHTX0", "version": "^2.0.6" },
    { "name": "7semi-solutions/7Semi MLX90393", "version": "^1.0.0" }
 ]
}
